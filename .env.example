# 이 파일을 복사해서 .env 로 만들고 실제 값을 채운 뒤 사용하세요.
# cp .env.example .env
#
# .env 파일 자체는 실제 API 키가 들어가므로 git에 커밋하지 마세요 (.gitignore에 추가 권장).

# 공공데이터포털 인증키 (소상공인 상권정보 + 국토부 실거래가 공용)
# 비어있으면 collect.py가 자동으로 샘플 모드로 동작함
DATA_GO_KR_KEY=

# 서울 열린데이터광장 인증키 (생활인구)
# 비어있으면 생활인구 수집만 생략되고 나머지는 정상 동작함
SEOUL_API_KEY=

# Oracle XE 접속 정보
ORACLE_USER=sangkwon
ORACLE_PW=
ORACLE_DSN=localhost/XEPDB1
